# Copiez ce fichier en ".env" pour le developpement local, ou definissez
# ces variables directement dans votre plateforme de deploiement (Render,
# Docker, etc.) en production. Aucune de ces valeurs ne doit etre commitee
# dans le depot — voir le README racine, section "Variables d'environnement
# obligatoires (backend)".
#
# Chaque microservice ne lit que les variables qui le concernent (voir
# backend/README.md, section "Variables d'environnement" et "Communications
# inter-services" pour le detail service par service). Ce fichier regroupe
# la liste complete pour eviter d'avoir un .env.example different par
# service.

# ---------------------------------------------------------------------------
# Secrets obligatoires (aucune valeur par defaut — le demarrage echoue sans)
# ---------------------------------------------------------------------------

# Secret partage pour signer/valider les tokens JWT. DOIT etre identique
# dans tous les microservices, sinon un service rejette silencieusement les
# tokens valides emis par auth-service. Generer par ex. avec :
#   openssl rand -base64 48
JWT_SECRET=

# Secret partage entre auth-service et utilisateur-service pour les appels
# internes (doit etre la meme valeur dans les deux services).
INTERNAL_SERVICE_SECRET=

# ---------------------------------------------------------------------------
# Base de donnees PostgreSQL (une valeur par service, ou une base commune
# en local avec des noms de base differents — voir backend/README.md)
# ---------------------------------------------------------------------------

DATABASE_URL=jdbc:postgresql://localhost:5432/nom_de_la_base
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=2026

# ---------------------------------------------------------------------------
# Port d'ecoute (varie selon le service — voir tableau Architecture du
# README backend pour la valeur par defaut de chacun)
# ---------------------------------------------------------------------------

PORT=8080

# ---------------------------------------------------------------------------
# Duree de validite des tokens JWT (en millisecondes) — certains services
# utilisent JWT_EXPIRATION, d'autres JWT_EXPIRATION_MS selon le nom de
# propriete historique du service (voir application.properties du service)
# ---------------------------------------------------------------------------

JWT_EXPIRATION=86400000
JWT_EXPIRATION_MS=86400000

# ---------------------------------------------------------------------------
# Eureka (decouverte de services)
# ---------------------------------------------------------------------------

EUREKA_URI=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost

# ---------------------------------------------------------------------------
# URLs inter-services (chaque service ne declare que celles qu'il appelle
# reellement — voir backend/README.md section "Communications inter-services")
# ---------------------------------------------------------------------------

UTILISATEUR_SERVICE_URL=http://localhost:8081
PRODUIT_SERVICE_URL=http://localhost:8082
AVIS_SERVICE_URL=http://localhost:8085
CERTIFICATION_SERVICE_URL=http://localhost:8086
PAIEMENT_SERVICE_URL=http://localhost:8087
COMMANDE_SERVICE_URL=http://localhost:8088

# URL du frontend deploye (utilisee par paiement-service pour construire
# les URLs de retour Simiz successUrl/cancelUrl)
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Passerelle de paiement Simiz (sandbox) — utilisees par paiement-service
# uniquement. Optionnelles en local : si absentes, le service bascule sur
# sa simulation locale de secours au lieu de planter au demarrage.
# ---------------------------------------------------------------------------

SIMIZ_SECRET_KEY=
SIMIZ_PUBLIC_KEY=
