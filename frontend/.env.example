# Copiez ce fichier en ".env" pour le developpement local, ou definissez
# ces variables directement dans votre plateforme de deploiement (Render,
# Netlify, etc.) en production. Aucune modification du code source n'est
# necessaire pour deployer — il suffit de changer ces URLs vers vos
# services backend deployes.

# Toutes les requetes passent desormais par la passerelle API (elle route
# /api/xxx/** vers le bon microservice via Eureka) au lieu de contacter
# directement le port de chaque service.
VITE_API_GATEWAY_URL=http://localhost:8765

# Optionnel : permet de contourner la passerelle pour contacter un service
# precis directement (utile pour le debogage local). A laisser
# desactivees (commentees) en usage normal.
# VITE_AUTH_SERVICE_URL=http://localhost:8080
# VITE_UTILISATEUR_SERVICE_URL=http://localhost:8081
# VITE_PRODUIT_SERVICE_URL=http://localhost:8082
# VITE_MESSAGE_SERVICE_URL=http://localhost:8083
# VITE_SIGNALEMENT_SERVICE_URL=http://localhost:8084
# VITE_AVIS_SERVICE_URL=http://localhost:8085
# VITE_CERTIFICATION_SERVICE_URL=http://localhost:8086
# VITE_PAIEMENT_SERVICE_URL=http://localhost:8087
# VITE_COMMANDE_SERVICE_URL=http://localhost:8088
# VITE_NOTIFICATION_SERVICE_URL=http://localhost:8089
