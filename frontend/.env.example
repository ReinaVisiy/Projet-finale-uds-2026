# Copy this file to .env for local development, or set these as
# environment variables in your deployment platform (Render, Netlify, etc.)
# for production. No source code changes are needed when deploying —
# just change these URLs to your deployed backend URLs.

# Every request now goes through the API Gateway (routes /api/xxx/** to
# the right microservice via Eureka) instead of hitting each service's
# own port directly.
VITE_API_GATEWAY_URL=http://localhost:8765

# Optional: override any single service to bypass the gateway and hit it
# directly (useful for local debugging). Leave these unset in normal use.
# VITE_AUTH_SERVICE_URL=http://localhost:8080
# VITE_UTILISATEUR_SERVICE_URL=http://localhost:8081
# VITE_PRODUIT_SERVICE_URL=http://localhost:8082
# VITE_MESSAGE_SERVICE_URL=http://localhost:8083
# VITE_SIGNALEMENT_SERVICE_URL=http://localhost:8084
# VITE_AVIS_SERVICE_URL=http://localhost:8085
# VITE_CERTIFICATION_SERVICE_URL=http://localhost:8086
# VITE_PAIEMENT_SERVICE_URL=http://localhost:8090
# VITE_COMMANDE_SERVICE_URL=http://localhost:8088
# VITE_NOTIFICATION_SERVICE_URL=http://localhost:8089
